{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://roua.news/specs/source.schema.json",
  "title": "Official Source",
  "type": "object",
  "required": ["id", "name", "slug", "type", "authorityScore", "reliability", "isActive"],
  "properties": {
    "id": { "type": "string", "pattern": "^c[a-z0-9]{20,}$" },
    "name": { "type": "string", "minLength": 2, "maxLength": 200 },
    "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "shortName": { "type": ["string", "null"], "maxLength": 50 },
    "country": { "type": ["string", "null"] },
    "countryCode": { "type": ["string", "null"], "pattern": "^[A-Z]{2}$" },
    "region": { "type": ["string", "null"], "enum": ["North America", "Europe", "MENA", "Asia", "Africa", "South America", "Global", null] },
    "type": {
      "type": "string",
      "enum": ["central_bank", "statistics", "regulator", "exchange", "ministry", "intl_org", "company", "energy", "metals", "agriculture", "transport", "crypto", "rating_agency", "other"]
    },
    "authorityScore": { "type": "integer", "minimum": 0, "maximum": 100 },
    "reliability": { "type": "string", "enum": ["official", "verified", "unverified"] },
    "website": { "type": ["string", "null"], "format": "uri" },
    "rss": { "type": ["string", "null"], "format": "uri" },
    "api": { "type": ["string", "null"], "format": "uri" },
    "accessMethods": { "type": "array", "items": { "type": "string", "enum": ["rss", "html", "pdf", "json", "xml", "csv", "xbrl"] } },
    "language": { "type": "string", "enum": ["en", "ar", "fr", "tr", "es"] },
    "updateFrequency": { "type": ["string", "null"], "enum": ["realtime", "daily", "weekly", "monthly", "quarterly", "ad_hoc", null] },
    "relatedAssets": { "type": "array", "items": { "type": "string" } },
    "isActive": { "type": "boolean" },
    "isVerified": { "type": "boolean" }
  }
}
