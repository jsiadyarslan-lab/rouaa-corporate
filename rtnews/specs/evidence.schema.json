{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://roua.news/specs/evidence.schema.json",
  "title": "Evidence",
  "type": "object",
  "required": ["id", "documentId", "type", "url"],
  "properties": {
    "id": { "type": "string", "pattern": "^c[a-z0-9]{20,}$" },
    "eventId": { "type": ["string", "null"] },
    "documentId": { "type": "string" },
    "type": { "type": "string", "enum": ["pdf", "html", "quote", "table", "chart"] },
    "url": { "type": "string", "format": "uri" },
    "paragraph": { "type": ["string", "null"] },
    "hash": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
    "fetchedAt": { "type": "string", "format": "date-time" }
  }
}
