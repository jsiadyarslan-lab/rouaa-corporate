{
  "name": "rouatradingnews",
  "version": "141.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000 2>&1 | tee dev.log",
    "build": "prisma generate && next build && if [ -d .next/standalone/rouatradingnews ]; then echo '⚠ Nested standalone detected — flattening...' && cp -r .next/standalone/rouatradingnews/* .next/standalone/ && cp -r .next/standalone/rouatradingnews/.next .next/standalone/ 2>/dev/null; rm -rf .next/standalone/rouatradingnews; fi && cp -r .next/static .next/standalone/.next/ && cp -r public .next/standalone/ && test -d .next/standalone/src && cp -r src/data .next/standalone/src/data 2>/dev/null || true",
    "build:standalone": "prisma generate && next build && if [ -d .next/standalone/rouatradingnews ]; then echo '⚠ Nested standalone detected — flattening...' && cp -r .next/standalone/rouatradingnews/* .next/standalone/ && cp -r .next/standalone/rouatradingnews/.next .next/standalone/ 2>/dev/null; rm -rf .next/standalone/rouatradingnews; fi && cp -r .next/static .next/standalone/.next/ && cp -r public .next/standalone/",
    "start": "HOSTNAME=0.0.0.0 PORT=${PORT:-8080} node .next/standalone/server.js",
    "start:prod": "HOSTNAME=0.0.0.0 PORT=${PORT:-8080} node server.js",
    "lint": "eslint .",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset",
    "advisor:backfill": "npx tsx src/scripts/advisor-backfill.ts",
    "advisor:monitor": "npx tsx src/scripts/advisor-monitor.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
