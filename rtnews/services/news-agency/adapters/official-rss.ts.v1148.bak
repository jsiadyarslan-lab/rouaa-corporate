interface OfficialFeed {
  id: string;
  name: string;
  nameAr: string;
  url: string;
  category: Category;
  sourceId: SourceId;  // 'FedRSS' for all RSS-based sources
  eventType: 'press_release' | 'speech' | 'data_release';
}

