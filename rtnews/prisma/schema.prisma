// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── News Models ────────────────────────────────────────────

model NewsItem {
  id               String     @id @default(cuid())
  title            String
  titleAr          String? // ترجمة عربية تلقائية
  summary          String     @default("")
  summaryAr        String? // ترجمة عربية تلقائية
  content          String?    @default("") // المحتوى الكامل للخبر
  contentAr        String? // المحتوى الكامل مترجم — null until filled by prefetchArticleContent
  source           String     @default("")
  sourceName       String?    @default("") // اسم المصدر الظاهر للمستخدم
  isOfficialSource Boolean    @default(false) // V1050: true = مصدر رسمي (بنك مركزي، وزارة), false = مصدر صحفي
  url              String     @default("") // originalUrl - رابط المصدر الخارجي
  category         String     @default("اقتصاد كلي")
  categoryId       String? // English category ID key (e.g. 'stocks', 'crypto', 'economy') — NEW for dual-column system
  sentiment        String     @default("neutral")
  sentimentScore   Int        @default(55)
  impactLevel      String     @default("low")
  impactScore      Int        @default(0) // V101: 0-100 importance score (economic + political + geopolitical impact)
  originalLanguage String     @default("en")
  locale           String     @default("ar") // 'ar' | 'en' — locale of the published content. Arabic pipeline → 'ar', English pipeline → 'en'
  newsType         String     @default("live") // live | breaking | article
  affectedAssets   String     @default("[]") // JSON array
  aiAnalysis       String? // JSON from AI analysis
  isPublished      Boolean    @default(false) // V38: FALSE until article is fully complete and published
  isReady          Boolean    @default(false) // TRUE only when content is fully processed (titleAr + contentAr + aiAnalysis) — IRREVERSIBLE once true
  processingStage  String     @default("fetched") // fetched → content_loaded → translated → analyzed → imaged
  retryCount       Int        @default(0) // Number of failed processing attempts — used to re-process
  rejectCount      Int        @default(0) // V118: Number of times AI filter rejected this article — after 3, no longer auto-reset
  lastError        String? // Last error message from failed processing step
  imageUrl         String?
  generatedImage   String? // Base64 encoded AI-generated illustrative image (V42: always base64, never external URL)
  slug             String? // URL-friendly slug for SEO (uniqueness enforced by @@unique([slug, locale]) below)
  views            Int        @default(0) // Article view count
  publishedAt      DateTime? // V42: When article was first published — set once, never changed
  fetchedAt        DateTime   @default(now())
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  bookmarks        Bookmark[]
  comments         Comment[]

  @@unique([slug, locale]) // V256: Composite unique — same slug allowed in different locales
  @@index([newsType, fetchedAt])
  @@index([category])
  @@index([categoryId])
  @@index([locale])
  @@index([sentiment])
  @@index([slug])
  @@index([url]) // For deduplication by originalUrl
  @@index([url, locale]) // For locale-aware deduplication
  @@index([isReady, fetchedAt]) // For homepage queries filtering ready articles
  @@index([isReady, locale, fetchedAt]) // For locale-filtered homepage queries
  @@index([processingStage])
  @@index([impactScore]) // V101: For priority sorting in article picker
  @@map("news_items")
}

// ─── News Archive Model (V118) ─────────────────────────────────
// Archive for old published articles — keeps the main table fast.
// Archived articles are NEVER deleted — they remain accessible via /archive/[slug].
// This table has the EXACT same structure as NewsItem for easy querying.

model NewsItemArchive {
  id               String    @id
  title            String
  titleAr          String?
  summary          String    @default("")
  summaryAr        String?
  content          String?   @default("")
  contentAr        String?
  source           String    @default("")
  sourceName       String?   @default("")
  url              String    @default("")
  category         String    @default("اقتصاد كلي")
  categoryId       String? // English category ID key — mirrors NewsItem
  sentiment        String    @default("neutral")
  sentimentScore   Int       @default(55)
  impactLevel      String    @default("low")
  impactScore      Int       @default(0)
  originalLanguage String    @default("en")
  locale           String    @default("ar") // 'ar' | 'en' — mirrors NewsItem
  newsType         String    @default("live")
  affectedAssets   String    @default("[]")
  aiAnalysis       String?
  isPublished      Boolean   @default(true)
  isReady          Boolean   @default(true)
  processingStage  String    @default("imaged")
  retryCount       Int       @default(0)
  rejectCount      Int       @default(0)
  lastError        String?
  imageUrl         String?
  generatedImage   String?
  slug             String? // (uniqueness enforced by @@unique([slug, locale]) below)
  views            Int       @default(0)
  publishedAt      DateTime?
  fetchedAt        DateTime  @default(now())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  archivedAt       DateTime  @default(now()) // When this article was archived

  @@unique([slug, locale]) // V256: Composite unique — same slug allowed in different locales
  @@index([newsType, fetchedAt])
  @@index([category])
  @@index([categoryId])
  @@index([locale])
  @@index([slug])
  @@index([archivedAt])
  @@map("news_item_archives")
}

model NewsFetchLog {
  id           String   @id @default(cuid())
  newsType     String // live | breaking
  status       String // success | partial | failed
  itemsFetched Int      @default(0)
  itemsSaved   Int      @default(0)
  errors       String   @default("")
  duration     Int      @default(0) // milliseconds
  createdAt    DateTime @default(now())

  @@index([newsType, createdAt])
  @@map("news_fetch_logs")
}

// ─── Pipeline Run Models ───────────────────────────────────

model PipelineRun {
  id                String    @id @default(cuid())
  status            String    @default("running") // running | completed | failed | cancelled
  trigger           String    @default("manual") // manual | cron | api
  config            String    @default("{}") // JSON: PipelineConfig
  articlesPublished Int       @default(0)
  articlesSkipped   Int       @default(0)
  articlesFailed    Int       @default(0)
  totalDuration     Int       @default(0) // milliseconds
  summary           String    @default("")
  stepsJson         String    @default("[]") // JSON: PipelineStep[]
  error             String?
  startedAt         DateTime  @default(now())
  completedAt       DateTime?

  @@index([status, startedAt])
  @@index([trigger])
  @@map("pipeline_runs")
}

model AgentLog {
  id            String   @id @default(cuid())
  pipelineRunId String?
  agent         String // researcher | analyst | writer | fact-checker | seo | editor | publisher | orchestrator
  action        String
  inputJson     String   @default("{}") // JSON
  outputJson    String   @default("null") // JSON
  success       Boolean  @default(true)
  duration      Int      @default(0) // milliseconds
  error         String?
  createdAt     DateTime @default(now())

  @@index([agent, createdAt])
  @@index([pipelineRunId])
  @@map("agent_logs")
}

// ─── Economic Calendar ─────────────────────────────────────

model CalendarEvent {
  id               String   @id @default(cuid())
  eventName        String
  eventNameAr      String?
  country          String
  currency         String
  eventDate        DateTime
  forecast         String?
  previous         String?
  actual           String?
  impact           String   @default("MEDIUM") // HIGH | MEDIUM | LOW
  source           String   @default("manual")
  isActualReleased Boolean  @default(false)
  createdAt        DateTime @default(now())

  @@index([eventDate])
  @@index([country])
  @@map("calendar_events")
}

// ─── User & Auth Models ──────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String? // For email/password auth
  image         String?
  role          String    @default("user") // user | pro | admin
  provider      String    @default("email") // email | google | passkey
  plan          String    @default("free") // free | pro | elite
  planExpiresAt DateTime?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  bookmarks         Bookmark[]
  notifications     Notification[]
  alerts            PriceAlert[]
  subscriptions     Subscription[]
  smartAlerts       SmartAlert[]
  discussions       Discussion[]
  discussionReplies DiscussionReply[]
  profile           UserProfile?
  accounts          Account[]
  sessions          Session[]
  passkeys          Passkey[]

  @@index([email])
  @@map("users")
}

// ─── NextAuth Models ──────────────────────────────────────────

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String // oauth | credentials | passkey
  provider          String // google | email | passkey
  providerAccountId String
  access_token      String?  @db.Text
  refresh_token     String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  createdAt  DateTime @default(now())

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Passkey {
  id           String   @id @default(cuid())
  userId       String
  credentialId String   @unique // Base64URL encoded
  publicKey    Bytes // COSE public key
  counter      Int      @default(0)
  deviceType   String   @default("singleDevice") // singleDevice | multiDevice
  backedUp     Boolean  @default(false)
  transports   String   @default("[]") // JSON: ["internal","hybrid","usb","ble","nfc"]
  name         String? // User-given name e.g. "iPhone 15"
  lastUsedAt   DateTime @default(now())
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([credentialId])
  @@map("passkeys")
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  newsId    String
  createdAt DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  newsItem NewsItem @relation(fields: [newsId], references: [id], onDelete: Cascade)

  @@unique([userId, newsId])
  @@index([userId])
  @@map("bookmarks")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("info") // info | alert | trade | system
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

model PriceAlert {
  id          String    @id @default(cuid())
  userId      String
  symbol      String
  targetPrice Float
  direction   String    @default("above") // above | below
  isTriggered Boolean   @default(false)
  createdAt   DateTime  @default(now())
  triggeredAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isTriggered])
  @@index([symbol, isTriggered])
  @@map("price_alerts")
}

// ─── Subscription Models ─────────────────────────────────────

model Subscription {
  id            String    @id @default(cuid())
  userId        String
  plan          String    @default("free") // free | pro | elite
  status        String    @default("active") // active | cancelled | expired
  startDate     DateTime  @default(now())
  endDate       DateTime?
  paymentMethod String?
  amount        Float?
  currency      String    @default("USD")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("subscriptions")
}

// ─── Newsletter & Contact Models ────────────────────────────

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  status    String   @default("active") // active | unsubscribed | bounced
  source    String   @default("website") // website | api | import
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([status])
  @@map("newsletter_subscribers")
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String   @default("")
  message   String
  status    String   @default("new") // new | read | replied | archived
  reply     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("contact_messages")
}

// ─── Site Settings Model ────────────────────────────────────

model SiteSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String @default("")
  type  String @default("string") // string | number | boolean | json
  group String @default("general") // general | news | ai | cache | system

  @@index([key])
  @@index([group])
  @@map("site_settings")
}

// ─── Smart Alert Models ────────────────────────────────────

model SmartAlert {
  id              String    @id @default(cuid())
  userId          String?
  alertType       String // price | sentiment | breaking | volume | custom
  symbol          String?
  condition       String // above | below | change_pct | keywords
  threshold       Float?
  keywords        String? // JSON array of keywords for news alerts
  isActive        Boolean   @default(true)
  isTriggered     Boolean   @default(false)
  lastTriggeredAt DateTime?
  createdAt       DateTime  @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@index([alertType, isActive])
  @@index([symbol, isActive, isTriggered])
  @@map("smart_alerts")
}

// ─── API Key Model (Public API) ────────────────────────────

model ApiKey {
  id         String    @id @default(cuid())
  userId     String?
  key        String    @unique
  name       String    @default("Default")
  plan       String    @default("free") // free | pro | enterprise
  rateLimit  Int       @default(100) // requests per hour
  isActive   Boolean   @default(true)
  lastUsedAt DateTime?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([key])
  @@index([userId])
  @@map("api_keys")
}

// ─── Community Models ──────────────────────────────────────

model Discussion {
  id         String   @id @default(cuid())
  userId     String
  title      String
  content    String
  category   String   @default("general") // general | analysis | question | idea
  tags       String   @default("[]") // JSON array
  upvotes    Int      @default(0)
  downvotes  Int      @default(0)
  replyCount Int      @default(0)
  isPinned   Boolean  @default(false)
  isLocked   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  replies DiscussionReply[]

  @@index([category, createdAt])
  @@index([userId])
  @@index([isPinned])
  @@map("discussions")
}

model DiscussionReply {
  id           String   @id @default(cuid())
  discussionId String
  userId       String
  content      String
  upvotes      Int      @default(0)
  isAccepted   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  discussion Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([discussionId, createdAt])
  @@index([userId])
  @@map("discussion_replies")
}

// ─── Telegram Integration ────────────────────────────────────

model TelegramAccount {
  id                String   @id @default(cuid())
  userId            String   @unique
  telegramChatId    String   @unique
  telegramUsername  String?
  notificationPrefs String   @default("{}") // JSON: { breaking: true, analysis: true, price: false, calendar: false, daily: false }
  isConnected       Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@index([telegramChatId])
  @@map("telegram_accounts")
}

// ─── Report Model (Automated Reports) ──────────────────────

model Report {
  id          String   @id @default(cuid())
  title       String
  reportType  String // daily | weekly | monthly | custom
  content     String // JSON: full report data
  summaryAr   String? // Arabic summary
  source      String? // V1219: content source
  sourceName  String? // V1219: display name for source
  period      String // e.g., "2026-04-23" or "2026-W17"
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([reportType, createdAt])
  @@index([isPublished])
  @@map("reports")
}

// ─── Comment Model (Article Comments) ─────────────────────

model Comment {
  id         String   @id @default(cuid())
  newsId     String
  content    String
  authorName String
  parentId   String?
  upvotes    Int      @default(0)
  downvotes  Int      @default(0)
  reports    Int      @default(0)
  isExpert   Boolean  @default(false)
  depth      Int      @default(0)
  createdAt  DateTime @default(now())

  news    NewsItem  @relation(fields: [newsId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies Comment[] @relation("CommentReplies")

  @@index([newsId, createdAt])
  @@index([parentId])
  @@index([upvotes])
  @@map("comments")
}

// ─── Monetization Models ───────────────────────────────────

model Advertisement {
  id          String    @id @default(cuid())
  title       String
  imageUrl    String
  targetUrl   String
  position    String    @default("sidebar") // top_banner | sidebar | bottom | inline
  isActive    Boolean   @default(true)
  impressions Int       @default(0)
  clicks      Int       @default(0)
  startDate   DateTime  @default(now())
  endDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([position, isActive])
  @@map("advertisements")
}

// ─── Economic Reports & Market Analysis (V61) ─────────────

model EconomicReport {
  id              String    @id @default(cuid())
  title           String
  slug            String // (uniqueness enforced by @@unique below)
  summary         String    @default("") // ملخص تنفيذي
  content         String    @default("") // المحتوى الكامل - Rich Text / Markdown
  reportType      String    @default("weekly") // weekly | monthly | quarterly | special
  scope           String    @default("global") // arabic | global | regional
  locale          String    @default("ar") // 'ar' | 'en' — locale of the report content
  source          String?   // V1219: content source (e.g. 'محرر رؤى الذكي')
  sourceName      String?   // V1219: display name for source
  sectors         String    @default("[]") // JSON: القطاعات المعنية
  countries       String    @default("[]") // JSON: الدول المعنية
  keyIndicators   String    @default("{}") // JSON: مؤشرات رئيسية
  marketImpact    String    @default("neutral") // bullish | bearish | neutral
  confidenceScore Int       @default(50) // 0-100
  sourceUrls      String    @default("[]") // JSON: المصادر
  imageUrl        String?
  isPublished     Boolean   @default(false)
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([slug, locale]) // V256: Composite unique — same slug allowed in different locales
  @@index([reportType, createdAt])
  @@index([scope, createdAt])
  @@index([locale])
  @@index([isPublished, publishedAt])
  @@index([isPublished, locale, publishedAt])
  @@map("economic_reports")
}

model MarketAnalysis {
  id              String    @id @default(cuid())
  title           String
  slug            String // (uniqueness enforced by @@unique below)
  assetClass      String    @default("stocks") // stocks | commodities | forex | crypto | bonds
  analysisType    String    @default("fundamental") // technical | fundamental | sentiment
  timeFrame       String    @default("daily") // intraday | daily | weekly | monthly
  locale          String    @default("ar") // 'ar' | 'en' — locale of the analysis content
  source          String?   // V1219: content source (e.g. 'محرر رؤى الذكي')
  sourceName      String?   // V1219: display name for source
  imageUrl        String?   // V1219e: image URL for the analysis
  content         String    @default("") // التحليل المفصل
  indicators      String    @default("{}") // JSON: RSI, MACD, Moving Averages
  priceTarget     String    @default("{}") // JSON: {current, target, stopLoss}
  riskLevel       String    @default("medium") // low | medium | high | extreme
  sentiment       String    @default("neutral") // bullish | bearish | neutral
  confidenceScore Int       @default(50) // 0-100
  sourceRef       String?
  relatedNewsIds  String    @default("[]") // JSON: IDs of related news
  isPublished     Boolean   @default(false)
  publishedAt     DateTime?
  validUntil      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  sectors       String @default("[]") // JSON: القطاعات المعنية
  countries     String @default("[]") // JSON: الدول المعنية
  keyIndicators String @default("{}") // JSON: مؤشرات رئيسية
  marketImpact  String @default("neutral") // bullish | bearish | neutral
  sourceUrls    String @default("[]") // JSON: المصادر

  @@unique([slug, locale]) // V256: Composite unique — same slug allowed in different locales
  @@index([assetClass, createdAt])
  @@index([analysisType, createdAt])
  @@index([isPublished, publishedAt])
  @@map("market_analyses")
}

model MarketIndicator {
  id            String   @id @default(cuid())
  name          String
  nameAr        String?
  symbol        String   @unique
  value         Float    @default(0)
  change        Float    @default(0)
  changePercent Float    @default(0)
  category      String   @default("index") // index | commodity | currency | bond_yield | crypto
  region        String   @default("global") // arabic | global
  history       String   @default("[]") // JSON: آخر 30 يوم [{date, value}]
  lastUpdated   DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([category, region])
  @@index([symbol])
  @@map("market_indicators")
}

// ─── Report Subscriptions (V62) ──────────────────────────────

model ReportSubscription {
  id           String   @id @default(cuid())
  email        String
  name         String?
  frequency    String   @default("daily") // daily | weekly | monthly | breaking
  categories   String   @default("[]") // JSON: selected categories
  regions      String   @default("[]") // JSON: selected regions
  isActive     Boolean  @default(true)
  confirmToken String?
  isConfirmed  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([email])
  @@index([frequency, isActive])
  @@index([confirmToken])
  @@map("report_subscriptions")
}

// ─── Economic Events (V62) ──────────────────────────────────

model EconomicEvent {
  id               String   @id @default(cuid())
  eventName        String
  eventNameAr      String?
  country          String
  currency         String
  eventDate        DateTime
  importance       String   @default("medium") // low | medium | high | critical
  eventType        String   @default("indicator") // indicator | speech | meeting | earnings | other
  forecast         String?
  previous         String?
  actual           String?
  source           String   @default("manual")
  isActualReleased Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([eventDate])
  @@index([country, eventDate])
  @@index([importance, eventDate])
  @@map("economic_events")
}

// ─── Infographic Model ──────────────────────────────────────

model Infographic {
  id           String    @id @default(cuid())
  slug         String // (uniqueness enforced by @@unique below)
  title        String
  subtitle     String?
  sourceType   String // "news" | "economic_report" | "market_analysis"
  sourceId     String?
  sourceTitle  String?
  category     String?
  locale       String    @default("ar") // 'ar' | 'en' — locale of the infographic content
  slides       Json // مصفوفة الشرائح (البيانات الهيكلية)
  thumbnailUrl String?
  impactScore  Int?
  viewCount    Int       @default(0)
  isPublished  Boolean   @default(false)
  publishedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([slug, locale]) // V256: Composite unique — same slug allowed in different locales
  @@index([sourceType, sourceId])
  @@index([category])
  @@index([locale])
  @@index([isPublished, publishedAt])
  @@index([isPublished, locale, publishedAt])
  @@map("infographics")
}

// ─── Video Reports (V317) ─────────────────────────────────────
// تقارير فيديو تحليلية مولّدة بالذكاء الاصطناعي

model VideoReport {
  id             String    @id @default(cuid())
  title          String
  slug           String
  symbol         String // e.g. "AAPL", "BTC-USD", "EURUSD=X"
