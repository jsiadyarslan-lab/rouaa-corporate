  videoUrl       String? // R2/S3 URL for the video file
  thumbnailUrl   String? // R2/S3 URL for the thumbnail
  duration       Float? // Duration in seconds
  sourceReportId String? // Linked EconomicReport or MarketAnalysis ID
  sourceType     String? // "economic_report" | "market_analysis"
  analysisText   String?   @default("") // The analysis text used for TTS
  chartMode      String    @default("bg") // "bg" (global) | "windows" (sliding)
  style          String    @default("pulse") // "pulse" (Bloomberg) | "dataviz" (Al Jazeera)
  marketImpact   String    @default("neutral") // bullish | bearish | neutral
  status         String    @default("pending") // pending | processing | completed | failed
  error          String? // Error message if failed
  viewCount      Int       @default(0)
  isPublished    Boolean   @default(false)
  publishedAt    DateTime?
