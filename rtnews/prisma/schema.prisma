// ─── Trading Signal Models (News Site) ──────────────────────
// الموقع الإخباري يحفظ الإشارات وبيانات المجلس الذكي للعرض والتتبع.
// ربط الحسابات والمحفظة الحقيقية في منصة التداول المنفصلة.

model TradingSignal {
  id             String    @id @default(cuid())
  pair           String // e.g. BTC/USDT, XAU/USD, EUR/USD
  action         String // BUY | SELL | WAIT
  confidence     Int       @default(50) // 0-100
  reason         String    @default("") // تحليل الإشارة بالعربية
  entryPrice     Float? // سعر الدخول
  stopLoss       Float? // وقف الخسارة
  takeProfit     Float? // جني الأرباح
  riskReward     Float? // نسبة المخاطرة/المكافأة
  status         String    @default("ACTIVE") // ACTIVE | EXECUTED | EXPIRED | CANCELLED | HIT_TP | HIT_SL
  source         String    @default("local-fallback") // local-fallback | trading-platform | council
  category       String    @default("forex") // forex | crypto | commodities | stocks
  timeframe      String    @default("H4") // H1 | H4 | D1 | W1
  resultPips     Float? // النتيجة بالنقاط (بعد الإغلاق)
  resultPercent  Float? // النتيجة بالنسبة المئوية
  closePrice     Float? // سعر الإغلاق
  profitPips     Float? // الربح بالنقاط
  profitPercent  Float? // الربح بالنسبة المئوية
  isWin          Boolean? // هل حققت الربح؟
  rsiAtSignal    Float? // قيمة RSI عند الإشارة
  sma20AtSignal  Float? // قيمة SMA20 عند الإشارة
  sma50AtSignal  Float? // قيمة SMA50 عند الإشارة
  councilVotes   String    @default("{}") // JSON: أصوات المجلس
  councilModels  String    @default("[]") // JSON: نماذج المجلس
  relatedNewsIds String    @default("[]") // JSON: أخبار مرتبطة
  notes          String? // ملاحظات
  closedAt       DateTime? // تاريخ إغلاق الإشارة
  expiresAt      DateTime? // تاريخ انتهاء الصلاحية
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // ربط بإحاطة المجلس الذكي (اختياري)
  councilBrief   CouncilBrief? @relation(fields: [councilBriefId], references: [id], onDelete: SetNull)
  councilBriefId String?       @unique

  @@index([status, createdAt])
  @@index([pair, status])
  @@index([action, status])
  @@index([source, createdAt])
  @@index([category])
  @@map("trading_signals")
}

model CouncilBrief {
  id              String    @id @default(cuid())
  pair            String // e.g. BTC/USDT
  direction       String // BUY | SELL
  entryPrice      Float
  stopLoss        Float
  takeProfit      Float
  confidence      Int       @default(50) // 0-100
  timeframe       String    @default("H4") // H1 | H4 | D1 | W1
  isActive        Boolean   @default(true)
  reviewStatus    String    @default("PENDING") // PENDING | APPROVED | REJECTED | EXPIRED
  analysisSummary String    @default("") // ملخص التحليل
  consensusJson   String    @default("{}") // JSON: {totalModels, buyVotes, sellVotes, neutralVotes}
  source          String    @default("local-fallback") // local-fallback | trading-platform
  sessionAt       DateTime? // وقت جلسة المجلس
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // الإشارة المرتبطة
  signal TradingSignal?

  @@index([isActive, createdAt])
  @@index([pair, isActive])
  @@index([reviewStatus])
  @@map("council_briefs")
}

// ─── مساعد رؤى — AI Personal Advisor Models ──────────────
// نظام التوصيات الشخصية المدعوم بالذكاء الاصطناعي

model UserProfile {
  id                 String    @id @default(cuid())
  userId             String    @unique
  experienceLevel    String    @default("beginner") // beginner | intermediate | advanced | professional
  riskTolerance      String    @default("moderate") // conservative | moderate | aggressive
  investmentHorizon  String    @default("medium") // short | medium | long
  preferredAssets    String    @default("[]") // JSON: ["forex", "commodities", "crypto", "stocks", "bonds"]
  preferredMarkets   String    @default("[]") // JSON: ["arabic", "global", "emerging"]
  capitalRange       String    @default("unknown") // under10k | 10k-50k | 50k-200k | 200k-1m | over1m | unknown
  tradingFrequency   String    @default("weekly") // daily | weekly | monthly | occasional
  interests          String    @default("[]") // JSON: topics of interest
  onboardingComplete Boolean   @default(false)
  onboardingStep     Int       @default(0) // Current step in onboarding flow
  lastAdvisorRun     DateTime? // Last time advisor generated recommendations
  advisorEnabled     Boolean   @default(true) // User can disable advisor
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // ─── حقول التوصية المتقدمة (PR#23) ────────────────────────
  excludedAssets              String  @default("[]") // JSON: أصول مستبعدة من التوصيات
  minConfidenceScore          Int     @default(40) // الحد الأدنى لعرض التوصية (0-100)
  successRate                 Float   @default(0) // معدل نجاح التوصيات المنفذة (0-100)
  allowGeneralRecommendations Boolean @default(false) // السماح بالتوصيات العامة

  user            User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  recommendations PersonalizedRecommendation[]

  @@index([userId])
  @@index([experienceLevel])
  @@index([riskTolerance])
  @@map("user_profiles")
}

model PersonalizedRecommendation {
  id                  String    @id @default(cuid())
  userId              String
  profileId           String
  recommendationType  String // asset_focus | market_opportunity | risk_alert | portfolio_rebalance | educational
  title               String // عنوان التوصية بالعربية
  titleEn             String? // English title
  summary             String    @default("") // ملخص التوصية
  reasoning           String    @default("") // مبرر التوصية بالعربية
  actionItems         String    @default("[]") // JSON: خطوات عملية
  relatedAssetClasses String    @default("[]") // JSON: فئات الأصول المرتبطة
  relatedSymbols      String    @default("[]") // JSON: الرموز المرتبطة
  relatedReportIds    String    @default("[]") // JSON: معرفات التقارير المرتبطة
  relatedNewsIds      String    @default("[]") // JSON: معرفات الأخبار المرتبطة
  confidenceScore     Int       @default(50) // 0-100
  urgencyLevel        String    @default("normal") // low | normal | high | critical
  validFrom           DateTime  @default(now())
  validUntil          DateTime?
  isRead              Boolean   @default(false)
  isDismissed         Boolean   @default(false)
  isActioned          Boolean   @default(false) // User took action on this recommendation
  userFeedback        String? // positive | negative | neutral
  sourceData          String    @default("{}") // JSON: البيانات المصدرية المستخدمة
  generatedBy         String    @default("advisor") // advisor | manual | scheduled

  // ─── حقول التوصية المتقدمة (PR#23) ────────────────────────
  reportId          String? // معرف التقرير المصدر (EconomicReport أو MarketAnalysis)
  reportSlug        String? // slug التقرير للرابط المباشر
  reportTitle       String? // عنوان التقرير للعرض السريع
  asset             String? // الأصل الموصى به (مثال: BTC/USD)
  action            String? // شراء | بيع | تجميع | مراقبة
  entryPrice        String? // سعر/مستوى الدخول
  targetPrice       String? // سعر الهدف
  stopLoss          String? // وقف الخسارة
  timeHorizon       String? // أفق زمني (مثال: أسبوعين)
  allocationPercent String? // نسبة التخصيص المقترحة (مثال: 5%)

  // ─── حقول التعلم من التفاعل (PR#23) ──────────────────────
  feedbackType     String? // executed | ignored | dismissed | useful | not_useful
  executedAt       DateTime? // وقت الضغط على "تم التنفيذ"
  executionPrice   String? // سعر التنفيذ الفعلي (اختياري)
  actualProfitLoss Float? // الربح/الخسارة الفعلي
  isSuccessful     Boolean? // هل حققت التوصية هدفها

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, isDismissed])
  @@index([userId, createdAt])
  @@index([recommendationType, urgencyLevel])
  @@index([validFrom, validUntil])
  @@index([asset])
  @@index([feedbackType])
  @@index([isSuccessful])
  @@map("personalized_recommendations")
}

